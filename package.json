{
  "name": "lime-scribe",
  "version": "1.0.0",
  "private": true,
  "description": "AI Scribe Notes Management Tool — Lime Challenge",
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "dev": "concurrently \"yarn dev:backend\" \"yarn dev:frontend\"",
    "dev:backend": "yarn --cwd backend start:dev",
    "dev:frontend": "yarn --cwd frontend dev",
    "build": "yarn build:backend && yarn build:frontend",
    "build:backend": "yarn --cwd backend build",
    "build:frontend": "yarn --cwd frontend build",
    "test": "yarn test:backend && yarn test:frontend",
    "test:backend": "yarn --cwd backend test",
    "test:frontend": "yarn --cwd frontend test",
    "test:coverage": "yarn test:coverage:backend && yarn test:coverage:frontend",
    "test:coverage:backend": "yarn --cwd backend test:cov",
    "test:coverage:frontend": "yarn --cwd frontend test:coverage",
    "lint": "yarn lint:backend && yarn lint:frontend",
    "lint:backend": "yarn --cwd backend lint",
    "lint:frontend": "yarn --cwd frontend lint",
    "install:all": "yarn install && yarn --cwd backend install && yarn --cwd frontend install"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^8.2.2"
  }
}
