# ─── Local Development ──────────────────────────────────────────────
# PostgreSQL connection (used by Docker Compose automatically)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=scribe_db

# Gemini AI — get your free key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Backend settings
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── AWS S3 (optional) ──────────────────────────────────────────────
# Leave these empty to use local file storage (uploads/ folder).
# Set all three to automatically switch to S3 storage — no code change needed.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ─── AWS Deployment (ECS + RDS) — only needed when deploying to AWS ─
# When using RDS, replace DATABASE_HOST with your RDS endpoint.
# DATABASE_HOST=your-rds-endpoint.rds.amazonaws.com
